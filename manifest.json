{
    "manifest_version": 2,
    "name": "History Blocker",
    "version": "1.0.0",
    "description": "Block browser history from being saved for specific sites",
    "permissions": [
        "history",
        "storage",
        "tabs",
        "<all_urls>"
    ],
    "background": {
        "scripts": [
            "background.js"
        ],
        "persistent": true
    },
    "options_ui": {
        "page": "options/options.html",
        "open_in_tab": true
    },
    "browser_action": {
        "default_icon": "icons/icon.svg",
        "default_title": "History Blocker"
    },
    "icons": {
        "48": "icons/icon.svg",
        "96": "icons/icon.svg"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "history-blocker@example",
            "strict_min_version": "60.0"
        }
    }
}